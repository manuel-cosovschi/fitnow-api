# MySQL connection
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=fitnow

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Public URL (ngrok / domain)
PUBLIC_BASE_URL=

# Security
JWT_SECRET=change_me_to_a_random_64_char_secret
JWT_EXPIRES_IN=30d

# CORS: comma-separated list of allowed origins (leave empty to allow all)
# Example: https://app.fitnow.com,https://admin.fitnow.com
ALLOWED_ORIGINS=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
