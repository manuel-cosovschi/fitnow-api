# PostgreSQL / Supabase connection
#
# IMPORTANT — Railway / Render / Fly (free) deployments:
# These platforms do NOT have outbound IPv6. The Supabase DIRECT connection
# host (db.<PROJECT-REF>.supabase.co) is IPv6-ONLY since 2024, so using it
# fails with: connect ENETUNREACH 2600:...:5432 - Local (:::0)
#
# ✅ Use the Supavisor POOLER URL (IPv4 compatible):
#    Supabase → Project Settings → Database → Connection string → "Transaction pooler"
#    Format:
#      postgresql://postgres.<PROJECT-REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres
#
# ❌ Do NOT use on Railway/Render/Fly (IPv6-only, will fail):
#      postgresql://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres
DATABASE_URL=

# Server
PORT=3000
HOST=0.0.0.0
# Set to "production" on any deployed environment
NODE_ENV=development

# Public URL — your deployed API URL (used in password-reset emails, etc.)
# Example: https://fitnow-api.up.railway.app  or  https://fitnow-api.onrender.com
PUBLIC_BASE_URL=

# Security — change to a random 64-char string before deploying
JWT_SECRET=change_me_to_a_random_64_char_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_a_different_64_char_secret
JWT_REFRESH_EXPIRES_IN=30d

# CORS — comma-separated list of allowed origins (leave empty to allow all, dev only)
# Example: https://app.fitnow.com,https://admin.fitnow.com
ALLOWED_ORIGINS=

# Logging
LOG_LEVEL=info

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Email — password reset (optional; if not set, reset links are logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fitnow.app

# Deep-link base URL for password reset (mobile app scheme or web URL)
RESET_PASSWORD_URL=fitnow://reset-password

# iOS deep-link scheme
IOS_DEEP_LINK_SCHEME=fitnow

# Public API base URL (used in webhook callbacks)
APP_BASE_URL=https://api.fitnow.com

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
MERCADOPAGO_PUBLIC_KEY=APP_USR-...
MERCADOPAGO_WEBHOOK_SECRET=

# OpenAI (AI Coach, gym plans, run routes, training plans)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# APNs (Push Notifications)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.fitnow.app
APNS_AUTH_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
APNS_PRODUCTION=true
