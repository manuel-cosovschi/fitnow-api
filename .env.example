# MySQL connection
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=fitnow
DB_PORT=3306
DB_CONNECTION_LIMIT=10

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Public URL (ngrok / domain for mobile clients)
PUBLIC_BASE_URL=

# Security — change to a random 64-char string before deploying
JWT_SECRET=change_me_to_a_random_64_char_secret
JWT_EXPIRES_IN=30d

# CORS — comma-separated list of allowed origins (leave empty to allow all, dev only)
# Example: https://app.fitnow.com,https://admin.fitnow.com
ALLOWED_ORIGINS=

# Logging
LOG_LEVEL=info

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Email — password reset (optional; if not set, reset links are logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fitnow.app

# Deep-link base URL for password reset (mobile app scheme or web URL)
RESET_PASSWORD_URL=fitnow://reset-password
